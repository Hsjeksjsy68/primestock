rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /products/{productId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /products/{productId}/comments/{commentId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /orders/{orderId} {
      allow read, create, update, delete: if request.auth != null;
    }
    match /support_requests/{requestId} {
      allow read, create, update, delete: if request.auth != null;
    }
    match /gift_cards/{cardId} {
      allow read, create, update, delete: if request.auth != null;
    }
    match /gift_card_templates/{templateId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /seller_approvals/{approvalId} {
      allow read, create, update, delete: if request.auth != null;
    }
    match /campaigns/{campaignId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /ads/{adId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /settings/{settingId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
